<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dev.project.user.UserMapper">

    <select id="selectUserByUserId" parameterType="String" resultType="com.dev.project.user.UserVo">
        SELECT
        *
        FROM user
        WHERE userId = #{userId}
    </select>

</mapper>